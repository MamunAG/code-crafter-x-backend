<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>We Received Your Message</title>
  </head>
  <body style="margin:0; padding:0; background:#f3f6fb; color:#111827; font-family:Arial, Helvetica, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f3f6fb; padding:32px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px; background:#ffffff; border:1px solid #e5e7eb; border-radius:18px; overflow:hidden;">
            <tr>
              <td style="padding:28px 32px; background:#08111f;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <img src="{{logoUrl}}" alt="{{appName}}" height="42" style="display:block; max-width:220px; height:42px; object-fit:contain;" />
                    </td>
                    <td align="right">
                      <img src="{{iconUrl}}" alt="" width="42" height="42" style="display:block; border-radius:12px;" />
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:38px 32px 18px;">
                <p style="margin:0 0 10px; color:#6b7280; font-size:13px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase;">Message received</p>
                <h1 style="margin:0; color:#111827; font-size:28px; line-height:1.25; font-weight:800;">Thanks, {{name}}.</h1>
                <p style="margin:16px 0 0; color:#4b5563; font-size:16px; line-height:1.7;">
                  We received your message and our support team will review it shortly. A copy of your submission is included below.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:12px 32px 34px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc; border:1px solid #dbe4f0; border-radius:16px;">
                  <tr>
                    <td style="padding:22px;">
                      <p style="margin:0 0 10px; color:#111827; font-size:15px;"><strong>Your email:</strong> {{email}}</p>
                      <p style="margin:0 0 18px; color:#111827; font-size:15px;"><strong>Account number:</strong> {{number}}</p>
                      <p style="margin:0 0 8px; color:#64748b; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:1px;">Your message</p>
                      <div style="padding:16px; background:#ffffff; border:1px solid #e5e7eb; border-radius:12px; color:#334155; font-size:15px; line-height:1.7;">{{message}}</div>
                    </td>
                  </tr>
                </table>

                <p style="margin:22px 0 0; color:#64748b; font-size:14px; line-height:1.7;">
                  If your matter is urgent, contact us directly at {{supportEmail}}.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:22px 32px; background:#f8fafc; border-top:1px solid #e5e7eb;">
                <p style="margin:0; color:#475569; font-size:14px; line-height:1.6;">Regards,<br /><strong>{{appName}} Support</strong></p>
                <p style="margin:14px 0 0; color:#94a3b8; font-size:12px; line-height:1.6;">This is an automated confirmation email.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
