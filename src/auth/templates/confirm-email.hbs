<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Email</title>
  </head>
  <body style="margin:0; padding:0; background:#f3f6fb; color:#111827; font-family:Arial, Helvetica, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f3f6fb; padding:32px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px; background:#ffffff; border:1px solid #e5e7eb; border-radius:18px; overflow:hidden;">
            <tr>
              <td style="padding:28px 32px; background:#08111f;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td style="vertical-align:middle;">
                      <img src="{{logoUrl}}" alt="{{appName}}" height="42" style="display:block; max-width:220px; height:42px; object-fit:contain;" />
                    </td>
                    <td align="right" style="vertical-align:middle;">
                      <img src="{{iconUrl}}" alt="" width="42" height="42" style="display:block; border-radius:12px;" />
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:38px 32px 16px;">
                <p style="margin:0 0 10px; color:#6b7280; font-size:13px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase;">Account verification</p>
                <h1 style="margin:0; color:#111827; font-size:28px; line-height:1.25; font-weight:800;">Verify your email address</h1>
                <p style="margin:16px 0 0; color:#4b5563; font-size:16px; line-height:1.7;">
                  Use the verification code below to confirm the email address for your {{appName}} account. Once verified, you can sign in and access your workspace.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:18px 32px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc; border:1px solid #dbe4f0; border-radius:16px;">
                  <tr>
                    <td align="center" style="padding:28px 20px;">
                      <p style="margin:0 0 10px; color:#64748b; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px;">Verification code</p>
                      <p style="margin:0; color:#4f46e5; font-family:'Courier New', Courier, monospace; font-size:42px; font-weight:800; letter-spacing:10px;">{{code}}</p>
                      <p style="margin:12px 0 0; color:#64748b; font-size:14px;">This code expires in 15 minutes.</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:8px 32px 34px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#eef2ff; border:1px solid #c7d2fe; border-radius:14px;">
                  <tr>
                    <td style="padding:16px 18px;">
                      <p style="margin:0; color:#3730a3; font-size:14px; line-height:1.6;">
                        <strong>Security note:</strong> If you did not create this account or request verification, you can safely ignore this email.
                      </p>
                    </td>
                  </tr>
                </table>

                <p style="margin:22px 0 0; color:#4b5563; font-size:15px; line-height:1.7;">
                  For your protection, this code can be used only once. Request a new code if it expires.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:22px 32px; background:#f8fafc; border-top:1px solid #e5e7eb;">
                <p style="margin:0; color:#475569; font-size:14px; line-height:1.6;">Regards,<br /><strong>{{appName}} Team</strong></p>
                <p style="margin:14px 0 0; color:#94a3b8; font-size:12px; line-height:1.6;">
                  This is an automated message. For help, contact {{supportEmail}}.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
