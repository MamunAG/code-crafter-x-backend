<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to {{appName}}</title>
  </head>
  <body style="margin:0; padding:0; background:#f3f6fb; color:#111827; font-family:Arial, Helvetica, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f3f6fb; padding:32px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px; background:#ffffff; border:1px solid #e5e7eb; border-radius:18px; overflow:hidden;">
            <tr>
              <td style="padding:30px 32px; background:#08111f;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <img src="{{logoUrl}}" alt="{{appName}}" height="42" style="display:block; max-width:220px; height:42px; object-fit:contain;" />
                    </td>
                    <td align="right">
                      <img src="{{iconUrl}}" alt="" width="42" height="42" style="display:block; border-radius:12px;" />
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:40px 32px 18px;">
                <p style="margin:0 0 10px; color:#6b7280; font-size:13px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase;">Welcome aboard</p>
                <h1 style="margin:0; color:#111827; font-size:30px; line-height:1.25; font-weight:800;">Hi {{fullName}}, your workspace is ready.</h1>
                <p style="margin:18px 0 0; color:#4b5563; font-size:16px; line-height:1.7;">
                  Your {{appName}} account has been created successfully. You can now sign in, manage your profile, and start working from your account dashboard.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:14px 32px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc; border:1px solid #dbe4f0; border-radius:16px;">
                  <tr>
                    <td style="padding:22px;">
                      <h2 style="margin:0 0 14px; color:#111827; font-size:18px;">What you can do next</h2>
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                        <tr>
                          <td style="padding:8px 0; color:#4b5563; font-size:15px;">Set up your profile and contact details.</td>
                        </tr>
                        <tr>
                          <td style="padding:8px 0; color:#4b5563; font-size:15px;">Review your account security and recovery email.</td>
                        </tr>
                        <tr>
                          <td style="padding:8px 0; color:#4b5563; font-size:15px;">Keep your session and notifications up to date.</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:18px 32px 38px;">
                <table role="presentation" cellspacing="0" cellpadding="0">
                  <tr>
                    <td style="border-radius:10px; background:#4f46e5;">
                      <a href="{{publicBaseUrl}}" style="display:inline-block; padding:13px 20px; color:#ffffff; font-size:15px; font-weight:700; text-decoration:none;">Open {{appName}}</a>
                    </td>
                  </tr>
                </table>
                <p style="margin:22px 0 0; color:#64748b; font-size:14px; line-height:1.7;">
                  If you have any questions, our team is available at {{supportEmail}}.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:22px 32px; background:#f8fafc; border-top:1px solid #e5e7eb;">
                <p style="margin:0; color:#475569; font-size:14px; line-height:1.6;">Regards,<br /><strong>{{appName}} Team</strong></p>
                <p style="margin:14px 0 0; color:#94a3b8; font-size:12px; line-height:1.6;">
                  This email was sent automatically after account registration.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
